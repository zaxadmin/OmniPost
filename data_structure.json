{
  "app": "OmniPost",
  "version": "1.0.0",
  "config": {
    "privacy_mode": {
      "default_hide_phone": true,
      "default_hide_address": true,
      "allow_email_only": true
    },
    "recruitment_fields": {
      "mandatory": ["job_title", "contract_type", "location_city"],
      "filters": ["experience_years", "caces_permis", "languages"]
    },
    "active_channels": {
      "jobboards": ["LinkedIn", "Indeed", "France_Travail"],
      "direct_mail": ["Agences_Interim"]
    }
  }
}
