{
  "app_identity": {
    "name": "OmniPost",
    "creator": "RAKOTOBE Liliane",
    "version": "1.1.0"
  },
  "international_settings": {
    "supported_languages": ["fr", "en"],
    "default_language": "fr",
    "currencies": ["EUR", "USD", "GBP"]
  },
  "form_logic": {
    "privacy_mode": {
      "hide_phone": true,
      "hide_exact_address": true
    },
    "job_categories": ["Tech", "Construction", "Retail", "Healthcare"],
    "filters": {
      "experience": ["Junior", "Intermediate", "Senior"],
      "requirements": ["Driving License", "Certifications", "Degree"]
    }
  },
  "distribution_channels": {
    "french_jobboards": ["France Travail", "Indeed FR", "Apec"],
    "english_jobboards": ["Monster", "Glassdoor", "LinkedIn Global", "Reed.co.uk"],
    "partners": ["Interim Agencies", "Recruitment Firms"]
  }
}
